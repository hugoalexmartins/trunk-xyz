{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "description": "Next.js frontend application",
  "scripts": {
    "build": "INLINE_RUNTIME_CHUNK=false dotenv -e ../.env -- next build",
    "build:check": "NEXT_DIST_DIR=.next-check INLINE_RUNTIME_CHUNK=false dotenv -e ../.env -- next build",
    "typecheck": "dotenv -e ../.env -- tsgo -p tsconfig.build.json --noEmit --skipLibCheck --incremental --tsBuildInfoFile .tsbuildinfo",
    "dev": "dotenv -e ../.env -- next dev",
    "dev:http": "dotenv -e ../.env -- next dev --experimental-https --experimental-https-key ./localhost+1-key.pem --experimental-https-cert ./localhost+1.pem",
    "lint": "dotenv -e ../.env -- eslint . --cache --cache-location .next/cache/eslint/ --max-warnings 0",
    "lint:fix": "dotenv -e ../.env -- eslint . --cache --cache-location .next/cache/eslint/ --fix",
    "clean": "rm -rf node_modules",
    "start": "dotenv -e ../.env -- sh -c 'NEXT_MANUAL_SIG_HANDLE=true next start'",
    "test": "cross-env NODE_OPTIONS='--no-experimental-require-module' dotenv -e ../.env.test -e ../.env -- jest --verbose --runInBand --selectProjects async-server",
    "test-client": "cross-env NODE_OPTIONS='--no-experimental-require-module' dotenv -e ../.env.test -e ../.env -- jest --verbose --selectProjects client"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "@tanstack/react-query": "^5.0.0",
    "bcryptjs": "^3.0.3",
    "jest-environment-jsdom": "^30.2.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.1.7",
    "next-themes": "^0.4.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "trpc": "latest"
  },
  "devDependencies": {
    "@jedmao/location": "^3.0.0",
    "@next/bundle-analyzer": "15.5.10",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@repo/config-eslint": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@tailwindcss/forms": "^0.5.7",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^15.0.7",
    "@types/bcryptjs": "^3.0.0",
    "@types/chroma-js": "^3.1.2",
    "@types/cors": "^2.8.17",
    "@types/dompurify": "^3.0.5",
    "@types/eslint": "^9.6.1",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.23",
    "@types/node": "24.3.0",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "@types/react-grid-layout": "^1.3.5",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@typescript/native-preview": "7.0.0-dev.20260122.3",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.39.2",
    "eslint-config-next": "15.5.10",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "node-mocks-http": "^1.14.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2",
    "wait-for-expect": "^3.0.2"
  },
  "ct3aMetadata": {
    "initVersion": "7.13.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.3",
      "@types/react-dom": "19.2.3"
    }
  }
}
