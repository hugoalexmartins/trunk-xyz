// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventType {
  APPLICATION
  SCREENING
  INTERVIEW
  OFFER
  REJECTION
  HIRED
}

enum EventStatus {
  PENDING
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum UserRole {
  admin
  regular
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  passwordHash String
  approved  Boolean   @default(false)
  role      UserRole  @default(regular)
  approvedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  events    Event[]

  @@index([email])
}

model Event {
  id        String   @id @default(cuid())
  pipelineId String?  // Optional UUID to group related events (e.g., recruitment journey)
  type      EventType
  status    EventStatus @default(PENDING)
  title     String
  description String?
  metadata  Json?     // Event-type-specific data stored as JSON
  date      DateTime  @default(now())
  createdById String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  creator   User?     @relation(fields: [createdById], references: [id])

  // Indexes for efficient querying
  @@index([pipelineId, createdAt])
  @@index([createdAt])
  @@index([type])
  @@index([createdById])
}
